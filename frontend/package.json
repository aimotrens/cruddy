  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@vitejs/plugin-vue": "6.0.6",
    "daisyui": "5.5.19",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vue-tsc": "3.2.7"
  }
